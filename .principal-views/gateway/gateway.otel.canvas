			"fromSide": "top",
			"toNode": "gateway-starting",
			"toSide": "right",
			"pv": {
				"edgeType": "flow"
			}
		}
	],
	"pv": {
		"name": "Gateway",
		"version": "1.0.0",
		"description": "Gateway server OTEL events - request handling, method dispatch, and lifecycle",
		"markdown": ".principal-views/gateway/gateway.md",
		"edgeTypes": {
			"flow": {
				"label": "Flow",
				"style": "solid",
				"width": 2,
				"color": "#22c55e"
