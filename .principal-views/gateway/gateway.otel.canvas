{
	"nodes": [
		{
			"id": "request-received",
			"type": "text",
			"x": 50,
			"y": 50,
			"width": 200,
			"height": 100,
			"text": "# Request Received\n\nGateway receives an incoming request (HTTP, WebSocket, or RPC).",
			"pv": {
				"event": {
					"name": "gateway.request.received",
					"attributes": {
						"method": {
							"type": "string",
							"required": true,
							"description": "RPC method name (e.g., chat.send, channels.status)"
						},
						"transport": {
							"type": "string",
							"required": true,
							"description": "Transport type: http, websocket, internal"
						},
						"requestId": {
							"type": "string",
							"required": false,
							"description": "Unique request identifier"
						}
					}
				},
				"references": ["src/gateway/server.impl.ts", "src/gateway/server-methods.ts"],
				"otel": {
					"kind": "event",
					"category": "lifecycle"
				},
				"shape": "rectangle",
				"fill": "#3b82f6",
				"stroke": "#1d4ed8",
				"status": "draft"
			},
			"color": "#3b82f6"
		},
		{
			"id": "request-routed",
			"type": "text",
			"x": 50,
			"y": 200,
			"width": 200,
			"height": 100,
			"text": "# Request Routed\n\nRequest matched to a method handler.",
			"pv": {
				"event": {
					"name": "gateway.request.routed",
					"attributes": {
						"method": {
							"type": "string",
							"required": true,
							"description": "RPC method name"
						},
						"namespace": {
							"type": "string",
							"required": true,
							"description": "Method namespace (chat, channels, config, etc.)"
						}
					}
				},
				"references": ["src/gateway/server-methods.ts"],
				"otel": {
					"kind": "event",
					"category": "operation"
				},
				"shape": "rectangle",
				"fill": "#3b82f6",
				"stroke": "#1d4ed8",
				"status": "draft"
			},
			"color": "#3b82f6"
		},
		{
			"id": "request-completed",
			"type": "text",
			"x": 50,
			"y": 350,
			"width": 200,
			"height": 100,
			"text": "# Request Completed\n\nRequest processing finished successfully.",
			"pv": {
				"event": {
					"name": "gateway.request.completed",
					"attributes": {
						"method": {
							"type": "string",
							"required": true,
							"description": "RPC method name"
						},
						"durationMs": {
							"type": "number",
							"required": false,
							"description": "Request duration in milliseconds"
						}
					}
				},
				"references": ["src/gateway/server.impl.ts"],
				"otel": {
					"kind": "event",
					"category": "lifecycle"
				},
				"shape": "rectangle",
				"fill": "#22c55e",
				"stroke": "#16a34a",
				"status": "draft"
			},
			"color": "#22c55e"
		},
		{
			"id": "request-timeout",
			"type": "text",
			"x": 300,
			"y": 350,
			"width": 200,
			"height": 100,
			"text": "# Request Timeout\n\nRequest timed out.",
			"pv": {
				"event": {
					"name": "gateway.request.timeout",
					"attributes": {
						"method": {
							"type": "string",
							"required": true,
							"description": "RPC method name"
						},
						"timeoutMs": {
							"type": "number",
							"required": false,
							"description": "Timeout threshold in milliseconds"
						},
						"durationMs": {
							"type": "number",
							"required": false,
							"description": "Actual duration before timeout"
						}
					}
				},
				"references": ["src/gateway/server.impl.ts"],
				"otel": {
					"kind": "event",
					"category": "error"
				},
