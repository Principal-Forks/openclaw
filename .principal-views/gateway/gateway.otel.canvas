	"edges": [
		{
			"id": "received-to-routed",
			"fromNode": "request-received",
			"fromSide": "bottom",
			"toNode": "request-routed",
			"toSide": "top",
			"pv": {
				"edgeType": "flow"
			}
		},
		{
			"id": "routed-to-completed",
			"fromNode": "request-routed",
			"fromSide": "bottom",
			"toNode": "request-completed",
			"toSide": "top",
			"pv": {
				"edgeType": "flow"
			}
		},
		{
			"id": "routed-to-error",
			"fromNode": "request-routed",
			"fromSide": "right",
			"toNode": "request-error",
			"toSide": "left",
			"pv": {
				"edgeType": "error"
			}
		},
		{
